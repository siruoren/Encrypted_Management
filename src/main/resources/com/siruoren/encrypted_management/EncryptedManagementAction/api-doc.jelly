                <!-- ==================== Audit Log ==================== -->
                <div class="swagger-tag">
                    <div class="swagger-tag-header" onclick="toggleTag(this)">
                        <div class="swagger-tag-icon" style="background:#f93e3e;">A</div>
                        <h2 class="swagger-tag-name">${%Audit Log}</h2>
                        <span class="swagger-tag-desc">${%Audit log management APIs}</span>
                    </div>
                    <div class="swagger-tag-body">

                        <!-- POST auditLog -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">auditLog</span>
                                <span class="swagger-summary">${%Query audit logs}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Retrieve recent audit log entries.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">limit</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Max entries to return - default 100 max 1000}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{
  "success": true,
  "logs": ["[2025-01-01 12:00:00.000] user=admin folder=... action=CREATE ..."],
  "count": 1,
  "maxRetentionDays": 30
}</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>limit</label><input type="text" id="param-auditLog-limit" placeholder="Default: 100, Max: 1000" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('auditLog', 'POST', {limit: gv('param-auditLog-limit')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-auditLog">
                                        <div class="swagger-try-curl" id="curl-auditLog"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST configureAuditLog -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">configureAuditLog</span>
                                <span class="swagger-summary">${%Configure audit log retention}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Set the maximum number of days to retain audit log files.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">maxRetentionDays</td><td><span class="param-required">REQUIRED</span></td><td>${%Max retention days 1 to 365}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "message": "Audit log retention configured to 30 days." }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>maxRetentionDays <span class="field-required">*</span></label><input type="text" id="param-configAudit-maxRetentionDays" placeholder="1 - 365" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('configureAuditLog', 'POST', {maxRetentionDays: gv('param-configAudit-maxRetentionDays')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-configureAuditLog">
                                        <div class="swagger-try-curl" id="curl-configureAuditLog"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- ==================== Backup & Restore ==================== -->
                <div class="swagger-tag">
                    <div class="swagger-tag-header" onclick="toggleTag(this)">
                        <div class="swagger-tag-icon" style="background:#e9967a;">B</div>
                        <h2 class="swagger-tag-name">${%Backup &amp; Restore}</h2>
                        <span class="swagger-tag-desc">${%Backup plus restore APIs}</span>
                    </div>
                    <div class="swagger-tag-body">

                        <!-- POST exportCredentials -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">exportCredentials</span>
                                <span class="swagger-summary">${%Export credentials as encrypted text}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Export all credentials as AES-256-GCM encrypted text data.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">password</td><td><span class="param-required">REQUIRED</span></td><td>${%Encryption password min 8 characters}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "data": "base64-encrypted-data...", "folder": "folder-name", "message": "Credentials exported successfully." }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>password <span class="field-required">*</span></label><input type="text" id="param-exportCred-password" placeholder="Encryption password (min 8 chars)" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('exportCredentials', 'POST', {password: gv('param-exportCred-password')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-exportCredentials">
                                        <div class="swagger-try-curl" id="curl-exportCredentials"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST exportCredentialsFile -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">exportCredentialsFile</span>
                                <span class="swagger-summary">${%Export credentials as encrypted file download}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Export all credentials as AES-256-GCM encrypted file .enc for download.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">password</td><td><span class="param-required">REQUIRED</span></td><td>${%Encryption password min 8 characters}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">${%Binary file download credentials-backup-folder-timestamp.enc}</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>password <span class="field-required">*</span></label><input type="text" id="param-exportFile-password" placeholder="Encryption password (min 8 chars)" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryFileDownload('exportCredentialsFile', {password: gv('param-exportFile-password')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-exportCredentialsFile">
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST importCredentials -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">importCredentials</span>
                                <span class="swagger-summary">${%Import credentials from encrypted data}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Import credentials from AES-256-GCM encrypted text data.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">password</td><td><span class="param-required">REQUIRED</span></td><td>${%Decryption password}</td></tr>
                                    <tr><td class="param-name">data</td><td><span class="param-required">REQUIRED</span></td><td>${%Encrypted backup data}</td></tr>
                                    <tr><td class="param-name">overwrite</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Overwrite existing credentials - yes / no}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "importResult": { "imported": 2, "updated": 0, "skipped": 1, "failed": 0 }, "message": "Credentials imported successfully" }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>password <span class="field-required">*</span></label><input type="text" id="param-importCred-password" placeholder="Decryption password" /></div>
                                        <div class="swagger-try-field"><label>data <span class="field-required">*</span></label><textarea id="param-importCred-data" placeholder="Paste encrypted backup data here"></textarea></div>
                                        <div class="swagger-try-field"><label>overwrite</label><input type="text" id="param-importCred-overwrite" placeholder="true / false" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('importCredentials', 'POST', {password: gv('param-importCred-password'), data: gv('param-importCred-data'), overwrite: gv('param-importCred-overwrite')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-importCredentials">
                                        <div class="swagger-try-curl" id="curl-importCredentials"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST importCredentialsFile -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">importCredentialsFile</span>
                                <span class="swagger-summary">${%Import credentials from uploaded file}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Import credentials from an uploaded encrypted backup file.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">password</td><td><span class="param-required">REQUIRED</span></td><td>${%Decryption password}</td></tr>
                                    <tr><td class="param-name">data</td><td><span class="param-required">REQUIRED</span></td><td>${%File content as text}</td></tr>
                                    <tr><td class="param-name">overwrite</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Overwrite existing credentials}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "importResult": { "imported": 2, "updated": 0, "skipped": 1, "failed": 0 }, "message": "Credentials imported successfully" }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>password <span class="field-required">*</span></label><input type="text" id="param-importFile-password" placeholder="Decryption password" /></div>
                                        <div class="swagger-try-field"><label>data <span class="field-required">*</span></label><textarea id="param-importFile-data" placeholder="Paste file content here or use file upload below"></textarea></div>
                                        <div class="swagger-try-field"><label></label><input type="file" id="param-importFile-file" accept=".enc,.txt" onchange="loadFileContent(this, 'param-importFile-data')" /></div>
                                        <div class="swagger-try-field"><label>overwrite</label><input type="text" id="param-importFile-overwrite" placeholder="true / false" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('importCredentialsFile', 'POST', {password: gv('param-importFile-password'), data: gv('param-importFile-data'), overwrite: gv('param-importFile-overwrite')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-importCredentialsFile">
                                        <div class="swagger-try-curl" id="curl-importCredentialsFile"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- ==================== External Storage ==================== -->
                <div class="swagger-tag">
                    <div class="swagger-tag-header" onclick="toggleTag(this)">
                        <div class="swagger-tag-icon" style="background:#61affe;">E</div>
                        <h2 class="swagger-tag-name">${%External Storage}</h2>
                        <span class="swagger-tag-desc">${%External storage management APIs}</span>
                    </div>
                    <div class="swagger-tag-body">

                        <!-- POST storageStatus -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">storageStatus</span>
                                <span class="swagger-summary">${%Get external storage status}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Get the current status with configuration of the external storage backend.}</div>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{
  "success": true,
  "enabled": true,
  "syncMode": "MANUAL",
  "storageType": "FILE",
  "connected": true,
  "encrypted": true,
  "storagePath": "/custom/path",
  "configInfo": { "type": "FILE", "path": "/custom/path", "writable": true, "encrypted": true }
}</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('storageStatus', 'POST')">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-storageStatus">
                                        <div class="swagger-try-curl" id="curl-storageStatus"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST configureStorage -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">configureStorage</span>
                                <span class="swagger-summary">${%Configure external storage}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Configure the external storage backend settings.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">enabled</td><td><span class="param-required">REQUIRED</span></td><td>${%Enable/disable external storage - yes / no}</td></tr>
                                    <tr><td class="param-name">syncMode</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Sync mode MANUAL AUTO_SYNC EXTERNAL_ONLY}</td></tr>
                                    <tr><td class="param-name">storagePath</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Custom storage path - leave blank for default}</td></tr>
                                    <tr><td class="param-name">encryptionPassword</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Password for AES-256-GCM encryption}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "message": "External storage configured successfully." }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>enabled <span class="field-required">*</span></label><input type="text" id="param-configStorage-enabled" placeholder="true / false" /></div>
                                        <div class="swagger-try-field"><label>syncMode</label><input type="text" id="param-configStorage-syncMode" placeholder="MANUAL / AUTO_SYNC / EXTERNAL_ONLY" /></div>
                                        <div class="swagger-try-field"><label>storagePath</label><input type="text" id="param-configStorage-storagePath" placeholder="Custom path (leave blank for default)" /></div>
                                        <div class="swagger-try-field"><label>encryptionPassword</label><input type="text" id="param-configStorage-encryptionPassword" placeholder="AES-256-GCM encryption password" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('configureStorage', 'POST', {enabled: gv('param-configStorage-enabled'), syncMode: gv('param-configStorage-syncMode'), storagePath: gv('param-configStorage-storagePath'), encryptionPassword: gv('param-configStorage-encryptionPassword')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-configureStorage">
                                        <div class="swagger-try-curl" id="curl-configureStorage"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST testStorageConnection -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">testStorageConnection</span>
                                <span class="swagger-summary">${%Test storage connection}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Test the connection to the external storage backend.}</div>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "connected": true }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('testStorageConnection', 'POST')">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-testStorageConnection">
                                        <div class="swagger-try-curl" id="curl-testStorageConnection"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST syncToExternal -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">syncToExternal</span>
                                <span class="swagger-summary">${%Sync credentials to external storage}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Asynchronously sync all credentials to the external storage backend.}</div>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "message": "Sync started in background for 5 credentials" }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('syncToExternal', 'POST')">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-syncToExternal">
                                        <div class="swagger-try-curl" id="curl-syncToExternal"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- ==================== Models ==================== -->
                <div class="swagger-models">
                    <h2>${%Schemas}</h2>
                    <div class="swagger-model">
                        <div class="swagger-model-header" onclick="toggleModel(this)">ApiResponse</div>
                        <div class="swagger-model-body">
                            <table><tr><th>${%Field}</th><th>${%Type}</th><th>${%Description}</th></tr>
                            <tr><td>success</td><td>boolean</td><td>${%Operation result status}</td></tr>
                            <tr><td>message</td><td>string</td><td>${%Result message}</td></tr></table>
                        </div>
                    </div>
                    <div class="swagger-model">
                        <div class="swagger-model-header" onclick="toggleModel(this)">Credential</div>
                        <div class="swagger-model-body">
                            <table><tr><th>${%Field}</th><th>${%Type}</th><th>${%Description}</th></tr>
                            <tr><td>id</td><td>string</td><td>${%Credential ID}</td></tr>
                            <tr><td>description</td><td>string</td><td>${%Description}</td></tr>
                            <tr><td>type</td><td>string</td><td>${%Credential type display name}</td></tr>
                            <tr><td>typeKey</td><td>string</td><td>USERNAME_PASSWORD | SECRET_TEXT | SSH_KEY</td></tr>
                            <tr><td>username</td><td>string</td><td>${%Username for USERNAME_PASSWORD plus SSH_KEY types}</td></tr></table>
                        </div>
                    </div>
                    <div class="swagger-model">
                        <div class="swagger-model-header" onclick="toggleModel(this)">ImportResult</div>
                        <div class="swagger-model-body">
                            <table><tr><th>${%Field}</th><th>${%Type}</th><th>${%Description}</th></tr>
                            <tr><td>imported</td><td>integer</td><td>${%Number of newly imported credentials}</td></tr>
                            <tr><td>updated</td><td>integer</td><td>${%Number of updated existing credentials}</td></tr>
                            <tr><td>skipped</td><td>integer</td><td>${%Number of skipped credentials}</td></tr>
                            <tr><td>failed</td><td>integer</td><td>${%Number of failed credentials}</td></tr></table>
                        </div>
                    </div>
                    <div class="swagger-model">
                        <div class="swagger-model-header" onclick="toggleModel(this)">StorageConfig</div>
                        <div class="swagger-model-body">
                            <table><tr><th>${%Field}</th><th>${%Type}</th><th>${%Description}</th></tr>
                            <tr><td>enabled</td><td>boolean</td><td>${%External storage enabled status}</td></tr>
                            <tr><td>syncMode</td><td>string</td><td>MANUAL | AUTO_SYNC | EXTERNAL_ONLY</td></tr>
                            <tr><td>storageType</td><td>string</td><td>${%Storage backend type}</td></tr>
                            <tr><td>connected</td><td>boolean</td><td>${%Connection status}</td></tr>
                            <tr><td>encrypted</td><td>boolean</td><td>${%Encryption enabled status}</td></tr>
                            <tr><td>storagePath</td><td>string</td><td>${%Custom storage path}</td></tr></table>
                        </div>
                    </div>
                </div>

                <st:once>
                    <script type="text/javascript">
                    //<![CDATA[
                        var baseUrl = document.location.href.replace(/api-doc\/?$/, '');
                        document.getElementById('api-base-url').textContent = baseUrl;

                        function gv(id) { var el = document.getElementById(id); return el ? el.value : ''; }

                        function toggleTag(header) {
                            var body = header.nextElementSibling;
                            if (body) body.style.display = body.style.display === 'none' ? 'block' : 'none';
                        }

                        function toggleEndpoint(header) {
                            var body = header.nextElementSibling;
                            if (body) body.classList.toggle('open');
                        }

                        function toggleModel(header) {
                            var body = header.nextElementSibling;
                            if (body) body.classList.toggle('open');
                        }

                        function loadFileContent(input, targetId) {
                            var file = input.files[0];
                            if (!file) return;
                            var reader = new FileReader();
                            reader.onload = function(e) {
                                document.getElementById(targetId).value = e.target.result;
                            };
                            reader.readAsText(file);
                        }

                        function tryApi(endpoint, method, params) {
                            var url = baseUrl + endpoint;
                            var crumbHeaderName = document.head.getAttribute('data-crumb-header') || 'Jenkins-Crumb';
                            var crumbValue = document.head.getAttribute('data-crumb-value') || '';
                            var fetchOptions = { method: method, headers: {} };
                            if (crumbValue) fetchOptions.headers[crumbHeaderName] = crumbValue;
                            if (method === 'POST' && params) {
                                fetchOptions.headers['Content-Type'] = 'application/x-www-form-urlencoded';
                                var bodyParts = [];
                                for (var key in params) {
                                    if (params[key]) bodyParts.push(encodeURIComponent(key) + '=' + encodeURIComponent(params[key]));
                                }
                                fetchOptions.body = bodyParts.join('&');
                            }

                            var resultDiv = document.getElementById('result-' + endpoint);
                            var curlDiv = document.getElementById('curl-' + endpoint);
                            if (resultDiv) {
                                resultDiv.style.display = 'block';
                                if (curlDiv) curlDiv.innerHTML = buildCurl(endpoint, method, params);
                                resultDiv.querySelector('pre').textContent = '${%Loading...}';
                            }

                            fetch(url, fetchOptions)
                                .then(function(r) { return r.text(); })
                                .then(function(text) {
                                    if (resultDiv) {
                                        try {
                                            var json = JSON.parse(text);
                                            resultDiv.querySelector('pre').textContent = JSON.stringify(json, null, 2);
                                        } catch(e) {
                                            resultDiv.querySelector('pre').textContent = text;
                                        }
                                    }
                                })
                                .catch(function(err) {
                                    if (resultDiv) resultDiv.querySelector('pre').textContent = 'Error: ' + err.message;
                                });
                        }

                        function buildCurl(endpoint, method, params) {
                            var url = baseUrl + endpoint;
                            var crumbHeaderName = document.head.getAttribute('data-crumb-header') || 'Jenkins-Crumb';
                            var crumbValue = document.head.getAttribute('data-crumb-value') || '';
                            var lines = [];
                            lines.push('<span class="curl-keyword">curl</span> <span class="curl-flag">-X</span> <span class="curl-string">' + method + '</span> \\');
                            lines.push('  <span class="curl-string">' + url + '</span> \\');
                            lines.push('  <span class="curl-flag">-H</span> <span class="curl-string">"Content-Type: application/x-www-form-urlencoded"</span>');
                            if (crumbValue) {
                                lines.push('  <span class="curl-flag">-H</span> <span class="curl-string">"' + crumbHeaderName + ': ' + crumbValue + '"</span>');
                            }
                            if (method === 'POST' && params) {
                                var bodyParts = [];
                                for (var key in params) {
                                    if (params[key]) bodyParts.push(encodeURIComponent(key) + '=' + encodeURIComponent(params[key]));
                                }
                                if (bodyParts.length > 0) {
                                    lines.push('  <span class="curl-flag">-d</span> <span class="curl-string">"' + bodyParts.join('&amp;') + '"</span>');
                                }
                            }
                            return lines.join('\n');
                        }

                        function tryFileDownload(endpoint, params) {
                            var form = document.createElement('form');
                            form.method = 'POST';
                            form.action = baseUrl + endpoint;

                            var crumbHeaderName = document.head.getAttribute('data-crumb-header') || 'Jenkins-Crumb';
                            var crumbValue = document.head.getAttribute('data-crumb-value') || '';
                            if (crumbValue) {
                                var crumbInput = document.createElement('input');
                                crumbInput.type = 'hidden';
                                crumbInput.name = crumbHeaderName;
                                crumbInput.value = crumbValue;
                                form.appendChild(crumbInput);
                            }

                            for (var key in params) {
                                if (params[key]) {
                                    var input = document.createElement('input');
                                    input.type = 'hidden';
                                    input.name = key;
                                    input.value = params[key];
                                    form.appendChild(input);
                                }
                            }

                            document.body.appendChild(form);
                            form.submit();
                            document.body.removeChild(form);
                        }
                    //]]>
                    </script>
                </st:once>
            </div>
        </l:main_panel>
    </l:layout>
</j:jelly>