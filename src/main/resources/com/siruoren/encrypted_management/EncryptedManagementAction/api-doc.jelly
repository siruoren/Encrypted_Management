<?jelly escape-by-default='false'?>
<j:jelly xmlns:j="jelly:core" xmlns:st="jelly:stapler" xmlns:l="/lib/layout" xmlns:t="/lib/hudson">
    <l:layout title="${%API Documentation} - ${it.folder.displayName}">
        <st:include page="sidepanel.jelly" it="${it.folder}" optional="true"/>
        <l:main_panel>
            <div id="swagger-ui">
                <!-- Top Bar -->
                <div class="swagger-topbar">
                    <div class="swagger-topbar-wrapper">
                        <a class="swagger-topbar-logo" href="api-doc">Encrypted Management API</a>
                        <a href="${rootURL}/${it.folder.url}Encrypted_Management/" class="swagger-back-btn">${%Back to Credentials Management}</a>
                    </div>
                </div>

                <!-- Info Section -->
                <div class="swagger-info">
                    <h1 class="swagger-title">${%Encrypted Management REST API}</h1>
                    <p class="swagger-description">${%API description}</p>
                    <div class="swagger-meta">
                        <span class="swagger-version">${%Version}: <strong>1.0.0</strong></span>
                        <span class="swagger-baseurl">${%Base URL}: <code id="api-base-url"></code></span>
                        <span class="swagger-auth">${%Authentication}: <strong> Jenkins Crumb + Session</strong></span>
                    </div>
                </div>

                <style>
                    #swagger-ui { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; color: #3b4151; }
                    .swagger-topbar { background: #1b1b1b; padding: 8px 0; }
                    .swagger-topbar-wrapper { max-width: 1200px; margin: 0 auto; padding: 0 20px; display: flex; align-items: center; justify-content: space-between; }
                    .swagger-topbar-logo { color: #fff; font-size: 1.3em; font-weight: bold; text-decoration: none; letter-spacing: 1px; }
                    .swagger-back-btn { color: #89bf04; text-decoration: none; font-size: 0.9em; border: 1px solid #89bf04; padding: 4px 12px; border-radius: 3px; }
                    .swagger-back-btn:hover { background: #89bf04; color: #1b1b1b; }
                    .swagger-info { max-width: 1200px; margin: 0 auto; padding: 20px 20px 10px; }
                    .swagger-title { font-size: 2em; margin: 0 0 5px; color: #3b4151; }
                    .swagger-description { color: #666; font-size: 1em; margin: 0 0 10px; }
                    .swagger-meta { display: flex; gap: 20px; flex-wrap: wrap; font-size: 0.85em; color: #888; }
                    .swagger-meta code { background: #f4f4f4; padding: 2px 6px; border-radius: 3px; font-size: 0.9em; }
                    .swagger-tag { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
                    .swagger-tag-header { display: flex; align-items: center; padding: 10px 0; cursor: pointer; border-bottom: 1px solid #eee; margin-top: 20px; }
                    .swagger-tag-header:hover { background: #fafafa; }
                    .swagger-tag-icon { width: 32px; height: 32px; background: #49cc90; border-radius: 3px; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: bold; margin-right: 10px; font-size: 1.1em; }
                    .swagger-tag-name { font-size: 1.4em; color: #3b4151; margin: 0; }
                    .swagger-tag-desc { color: #888; font-size: 0.85em; margin-left: 10px; }
                    .swagger-endpoint { border: 1px solid #ddd; margin: 10px 0; border-radius: 4px; overflow: hidden; }
                    .swagger-endpoint-header { display: flex; align-items: center; padding: 8px 12px; cursor: pointer; background: #f8f8f8; }
                    .swagger-endpoint-header:hover { background: #f0f0f0; }
                    .swagger-method { font-weight: bold; padding: 4px 8px; border-radius: 3px; color: #fff; font-size: 0.8em; min-width: 70px; text-align: center; margin-right: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
                    .method-get { background: #61affe; }
                    .method-post { background: #49cc90; }
                    .swagger-path { font-family: monospace; font-size: 0.95em; color: #333; font-weight: 600; }
                    .swagger-summary { margin-left: auto; color: #888; font-size: 0.85em; }
                    .swagger-endpoint-body { display: none; border-top: 1px solid #ddd; padding: 15px 20px; background: #fff; }
                    .swagger-endpoint-body.open { display: block; }
                    .swagger-endpoint-desc { color: #555; font-size: 0.9em; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #f0f0f0; }
                    .swagger-params-title { font-size: 0.95em; font-weight: 700; margin: 10px 0 5px; color: #3b4151; }
                    .swagger-params { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
                    .swagger-params th { background: #f7f7f7; padding: 8px 10px; text-align: left; font-size: 0.85em; color: #666; border: 1px solid #ddd; }
                    .swagger-params td { padding: 8px 10px; border: 1px solid #ddd; font-size: 0.85em; vertical-align: top; }
                    .swagger-params .param-name { font-family: monospace; font-weight: 600; color: #3b4151; }
                    .swagger-params .param-required { color: #e74c3c; font-weight: bold; font-size: 0.75em; }
                    .swagger-params .param-optional { color: #999; font-size: 0.75em; }
                    .swagger-response-title { font-size: 0.95em; font-weight: 700; margin: 10px 0 5px; color: #3b4151; }
                    .swagger-response-code { font-size: 0.85em; color: #49cc90; font-weight: 600; margin-bottom: 5px; }
                    .swagger-response-pre { background: #f4f4f4; border: 1px solid #ddd; border-radius: 4px; padding: 10px; font-size: 0.82em; overflow-x: auto; white-space: pre-wrap; word-break: break-all; line-height: 1.5; }
                    .swagger-try-section { margin-top: 15px; border-top: 2px solid #49cc90; padding-top: 12px; }
                    .swagger-try-title { font-size: 0.95em; font-weight: 700; color: #3b4151; margin-bottom: 8px; }
                    .swagger-try-inputs { margin-bottom: 10px; }
                    .swagger-try-field { display: flex; align-items: flex-start; margin-bottom: 6px; }
                    .swagger-try-field label { width: 160px; font-family: monospace; font-size: 0.85em; font-weight: 600; color: #3b4151; flex-shrink: 0; padding-top: 6px; }
                    .swagger-try-field label .field-required { color: #e74c3c; margin-left: 2px; }
                    .swagger-try-field input[type="text"], .swagger-try-field textarea { flex: 1; padding: 6px 10px; border: 1px solid #ccc; border-radius: 3px; font-size: 0.85em; font-family: monospace; }
                    .swagger-try-field textarea { min-height: 60px; resize: vertical; }
                    .swagger-try-field input:focus, .swagger-try-field textarea:focus { border-color: #49cc90; outline: none; box-shadow: 0 0 0 2px rgba(73,204,144,0.2); }
                    .swagger-try-field input[type="file"] { flex: 1; font-size: 0.85em; }
                    .swagger-try-btn { margin-top: 10px; }
                    .swagger-try-btn button { background: #49cc90; color: #fff; border: none; padding: 8px 20px; border-radius: 3px; cursor: pointer; font-size: 0.85em; font-weight: 600; }
                    .swagger-try-btn button:hover { background: #3daf7c; }
                    .swagger-try-result { margin-top: 10px; display: none; }
                    .swagger-try-result-label { font-size: 0.85em; font-weight: 600; color: #3b4151; margin-bottom: 4px; }
                    .swagger-try-result pre { background: #1b1b1b; color: #89bf04; border-radius: 4px; padding: 10px; font-size: 0.82em; max-height: 300px; overflow-y: auto; white-space: pre-wrap; word-break: break-all; line-height: 1.5; }
                    .swagger-try-curl { background: #2d2d2d; color: #a9b7c6; border-radius: 4px; padding: 10px; font-size: 0.82em; margin-top: 8px; white-space: pre-wrap; word-break: break-all; line-height: 1.5; }
                    .swagger-try-curl .curl-keyword { color: #cc7832; }
                    .swagger-try-curl .curl-string { color: #6a8759; }
                    .swagger-try-curl .curl-flag { color: #ffc66d; }
                    .swagger-models { max-width: 1200px; margin: 20px auto; padding: 0 20px; }
                    .swagger-models h2 { font-size: 1.4em; color: #3b4151; border-bottom: 2px solid #49cc90; padding-bottom: 5px; }
                    .swagger-model { border: 1px solid #ddd; border-radius: 4px; margin: 10px 0; overflow: hidden; }
                    .swagger-model-header { background: #f7f7f7; padding: 8px 12px; cursor: pointer; font-weight: 600; font-size: 0.95em; }
                    .swagger-model-header:hover { background: #f0f0f0; }
                    .swagger-model-body { display: none; padding: 10px 15px; border-top: 1px solid #ddd; }
                    .swagger-model-body.open { display: block; }
                    .swagger-model-body table { width: 100%; border-collapse: collapse; }
                    .swagger-model-body th { background: #eee; padding: 6px 10px; text-align: left; font-size: 0.82em; color: #666; border: 1px solid #ddd; }
                    .swagger-model-body td { padding: 6px 10px; border: 1px solid #ddd; font-size: 0.82em; }
                </style>

                <!-- ==================== Credentials ==================== -->
                <div class="swagger-tag">
                    <div class="swagger-tag-header" onclick="toggleTag(this)">
                        <div class="swagger-tag-icon">C</div>
                        <h2 class="swagger-tag-name">${%Credentials}</h2>
                        <span class="swagger-tag-desc">${%Credential management APIs}</span>
                    </div>
                    <div class="swagger-tag-body">

                        <!-- GET listCredentials -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-get">GET</span>
                                <span class="swagger-path">listCredentials</span>
                                <span class="swagger-summary">${%List all credentials}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Returns all credentials in the current folder with their metadata.}</div>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{
  "success": true,
  "credentials": [
    { "id": "credential-id", "description": "description", "type": "Username with password", "typeKey": "USERNAME_PASSWORD", "username": "admin" }
  ],
  "folder": "folder-name",
  "count": 1
}</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('listCredentials', 'GET')">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-listCredentials">
                                        <div class="swagger-try-curl" id="curl-listCredentials"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST decryptCredential -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">decryptCredential</span>
                                <span class="swagger-summary">${%Decrypt a credential}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Decrypt then return the secret values of a specified credential.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">id</td><td><span class="param-required">REQUIRED</span></td><td>${%Credential ID}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{
  "success": true,
  "id": "credential-id",
  "type": "Username with password",
  "typeKey": "USERNAME_PASSWORD",
  "username": "admin",
  "password": "secret-value"
}</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>id <span class="field-required">*</span></label><input type="text" id="param-decryptCredential-id" placeholder="e.g. my-credential-id" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('decryptCredential', 'POST', {id: gv('param-decryptCredential-id')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-decryptCredential">
                                        <div class="swagger-try-curl" id="curl-decryptCredential"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST createSecretText -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">createSecretText</span>
                                <span class="swagger-summary">${%Create Secret Text credential}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Create Secret Text credential in the folder.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">id</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Credential ID - leave blank for auto-generation}</td></tr>
                                    <tr><td class="param-name">description</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Description}</td></tr>
                                    <tr><td class="param-name">secret</td><td><span class="param-required">REQUIRED</span></td><td>${%Secret value}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "id": "auto-generated-id", "message": "Secret Text credential created successfully." }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>id</label><input type="text" id="param-createSecretText-id" placeholder="Leave blank for auto-generation" /></div>
                                        <div class="swagger-try-field"><label>description</label><input type="text" id="param-createSecretText-description" placeholder="Credential description" /></div>
                                        <div class="swagger-try-field"><label>secret <span class="field-required">*</span></label><input type="text" id="param-createSecretText-secret" placeholder="Secret text value" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('createSecretText', 'POST', {id: gv('param-createSecretText-id'), description: gv('param-createSecretText-description'), secret: gv('param-createSecretText-secret')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-createSecretText">
                                        <div class="swagger-try-curl" id="curl-createSecretText"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST createUsernamePassword -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">createUsernamePassword</span>
                                <span class="swagger-summary">${%Create Username/Password credential}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Create Username with Password credential in the folder.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">id</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Credential ID}</td></tr>
                                    <tr><td class="param-name">description</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Description}</td></tr>
                                    <tr><td class="param-name">username</td><td><span class="param-required">REQUIRED</span></td><td>${%Username}</td></tr>
                                    <tr><td class="param-name">password</td><td><span class="param-required">REQUIRED</span></td><td>${%Password}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "id": "auto-generated-id", "message": "Username/Password credential created successfully." }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>id</label><input type="text" id="param-createUP-id" placeholder="Leave blank for auto-generation" /></div>
                                        <div class="swagger-try-field"><label>description</label><input type="text" id="param-createUP-description" placeholder="Credential description" /></div>
                                        <div class="swagger-try-field"><label>username <span class="field-required">*</span></label><input type="text" id="param-createUP-username" placeholder="Username" /></div>
                                        <div class="swagger-try-field"><label>password <span class="field-required">*</span></label><input type="text" id="param-createUP-password" placeholder="Password" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('createUsernamePassword', 'POST', {id: gv('param-createUP-id'), description: gv('param-createUP-description'), username: gv('param-createUP-username'), password: gv('param-createUP-password')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-createUsernamePassword">
                                        <div class="swagger-try-curl" id="curl-createUsernamePassword"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST createSSHKey -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">createSSHKey</span>
                                <span class="swagger-summary">${%Create SSH Key credential}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Create SSH Username with Private Key credential in the folder.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">id</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Credential ID}</td></tr>
                                    <tr><td class="param-name">description</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Description}</td></tr>
                                    <tr><td class="param-name">username</td><td><span class="param-required">REQUIRED</span></td><td>${%Username}</td></tr>
                                    <tr><td class="param-name">passphrase</td><td><span class="param-optional">OPTIONAL</span></td><td>${%Passphrase for the private key}</td></tr>
                                    <tr><td class="param-name">privateKey</td><td><span class="param-required">REQUIRED</span></td><td>${%Private key content}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "id": "auto-generated-id", "message": "SSH Key credential created successfully." }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>id</label><input type="text" id="param-createSSH-id" placeholder="Leave blank for auto-generation" /></div>
                                        <div class="swagger-try-field"><label>description</label><input type="text" id="param-createSSH-description" placeholder="Credential description" /></div>
                                        <div class="swagger-try-field"><label>username <span class="field-required">*</span></label><input type="text" id="param-createSSH-username" placeholder="SSH username" /></div>
                                        <div class="swagger-try-field"><label>passphrase</label><input type="text" id="param-createSSH-passphrase" placeholder="Passphrase (optional)" /></div>
                                        <div class="swagger-try-field"><label>privateKey <span class="field-required">*</span></label><textarea id="param-createSSH-privateKey" placeholder="-----BEGIN RSA PRIVATE KEY-----&#10;...&#10;-----END RSA PRIVATE KEY-----"></textarea></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('createSSHKey', 'POST', {id: gv('param-createSSH-id'), description: gv('param-createSSH-description'), username: gv('param-createSSH-username'), passphrase: gv('param-createSSH-passphrase'), privateKey: gv('param-createSSH-privateKey')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-createSSHKey">
                                        <div class="swagger-try-curl" id="curl-createSSHKey"></div>
                                        <div class="swagger-try-result-label">${%Response}</div>
                                        <pre></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- POST updateSecretText -->
                        <div class="swagger-endpoint">
                            <div class="swagger-endpoint-header" onclick="toggleEndpoint(this)">
                                <span class="swagger-method method-post">POST</span>
                                <span class="swagger-path">updateSecretText</span>
                                <span class="swagger-summary">${%Update Secret Text credential}</span>
                            </div>
                            <div class="swagger-endpoint-body">
                                <div class="swagger-endpoint-desc">${%Update an existing Secret Text credential.}</div>
                                <div class="swagger-params-title">${%Parameters}</div>
                                <table class="swagger-params">
                                    <tr><th>${%Name}</th><th>${%Required}</th><th>${%Description}</th></tr>
                                    <tr><td class="param-name">id</td><td><span class="param-required">REQUIRED</span></td><td>${%Credential ID}</td></tr>
                                    <tr><td class="param-name">description</td><td><span class="param-optional">OPTIONAL</span></td><td>${%New description}</td></tr>
                                    <tr><td class="param-name">secret</td><td><span class="param-optional">OPTIONAL</span></td><td>${%New secret value - leave blank to keep current}</td></tr>
                                </table>
                                <div class="swagger-response-title">${%Response}</div>
                                <div class="swagger-response-code">200 OK</div>
                                <pre class="swagger-response-pre">{ "success": true, "message": "Secret Text credential updated successfully." }</pre>
                                <div class="swagger-try-section">
                                    <div class="swagger-try-title">${%Try it}</div>
                                    <div class="swagger-try-inputs">
                                        <div class="swagger-try-field"><label>id <span class="field-required">*</span></label><input type="text" id="param-updateST-id" placeholder="Credential ID to update" /></div>
                                        <div class="swagger-try-field"><label>description</label><input type="text" id="param-updateST-description" placeholder="New description" /></div>
                                        <div class="swagger-try-field"><label>secret</label><input type="text" id="param-updateST-secret" placeholder="New secret value (leave blank to keep)" /></div>
                                    </div>
                                    <div class="swagger-try-btn">
                                        <button onclick="tryApi('updateSecretText', 'POST', {id: gv('param-updateST-id'), description: gv('param-updateST-description'), secret: gv('param-updateST-secret')})">${%Try it}</button>
                                    </div>
                                    <div class="swagger-try-result" id="result-updateSecretText">
